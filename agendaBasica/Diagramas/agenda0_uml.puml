skinparam componentStyle rectangle
skinparam packageBackgroundColor #F5F5F5
skinparam componentBackgroundColor #DDEEFF
skinparam componentBorderColor #4A90D9
skinparam ArrowColor #333333
skinparam defaultFontSize 12

package "agenda0.py" {

    package "Interface de Usuário (UI)" #EAF4FF {
        component [menu_principal()]  as MENU
        component [cabecalho()]       as CAB
        component [linha()]           as LIN
        component [limpar()]          as LIMP
        component [pausar()]          as PAUS
        component [entrada()]         as ENT
        component [exibir_contato()]  as EXIB
    }

    package "CRUD — Lógica de Negócio" #E8FFE8 {
        component [criar_contato()]   as CR
        component [listar_contatos()] as LS
        component [buscar_contato()]  as BU
        component [exibir_detalhes()] as ED
        component [editar_contato()]  as ET
        component [excluir_contato()] as EX
    }

    package "Validação" #FFF8DC {
        component [validar_email()]    as VE
        component [validar_telefone()] as VT
        component [RE_EMAIL]           as RE1
