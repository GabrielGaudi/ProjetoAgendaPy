' ──────────────────────────────────────────────────────────────
'  1. DIAGRAMA DE CASOS DE USO
' ──────────────────────────────────────────────────────────────
@startuml 01_casos_de_uso
title Diagrama de Casos de Uso — agenda0.py (sem persistência)

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecaseBorderColor #4A90D9
skinparam usecaseBackgroundColor #EAF4FF
skinparam actorBorderColor #2C5F8A
skinparam ArrowColor #2C5F8A

actor "Usuário" as U

rectangle "Agenda de Contatos (sem persistência)" {
    usecase "Adicionar contato"   as UC1
    usecase "Listar contatos"     as UC2
    usecase "Buscar contato"      as UC3
    usecase "Ver detalhes"        as UC4
    usecase "Editar contato"      as UC5
    usecase "Excluir contato"     as UC6
    usecase "Validar e-mail"      as UC7
    usecase "Validar telefone"    as UC8
}

note bottom of UC2
  Dados existem apenas
  em memória — perdidos
  ao encerrar o programa
end note

U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5
U --> UC6

UC1 ..> UC7 : <<include>>
UC1 ..> UC8 : <<include>>
UC5 ..> UC7 : <<include>>
UC5 ..> UC8 : <<include>>
@enduml


